# Copy to .env locally. On Render, set these in the service Environment tab (do not upload .env).

# Server (Render sets PORT automatically)
PORT=5000

# Required for JWT auth — use a long random string in production
JWT_SECRET=your_secure_random_string_here

# Optional: GNews API for Current Affairs (https://gnews.io/)
GNEWS_API_KEY=

# Optional: MongoDB if you switch from file-based storage
# MONGO_URI=mongodb://localhost:27017/focusync
