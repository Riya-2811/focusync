# Backend origin only (no /api path, no trailing slash).
# Local dev: leave unset — requests use /api and CRA proxy → http://localhost:5000
#
# Render Static Site (production): point at your Web Service, e.g.:
# REACT_APP_API_URL=https://focusync.onrender.com
#
# If unset in production builds, utils/api.js uses FALLBACK_PRODUCTION_ORIGIN (same URL by default).
